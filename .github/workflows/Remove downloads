name: پاک‌کن پوشه downloads

on:
  workflow_dispatch:
    description: 'حذف تمام فایل‌ها و زیرپوشه‌های داخل downloads/'

permissions:
  contents: write

jobs:
  clean-downloads:
    runs-on: ubuntu-latest
    steps:
      - name: 📂 Checkout repository
        uses: actions/checkout@v4
        with:
          token: ${{ secrets.GITHUB_TOKEN }}

      - name: 🗑️ Remove everything inside downloads/
        run: |
          # اگر پوشه downloads وجود دارد، محتویات آن را حذف کن
          if [ -d "downloads" ]; then
            # حذف همه فایل‌ها و زیرپوشه‌ها (به جز خود پوشه)
            rm -rf downloads/*
            echo "✅ تمام محتویات پوشه downloads پاک شد."
          else
            echo "⚠️ پوشه downloads وجود ندارد، کاری انجام نشد."
          fi

      - name: 📤 Commit and push changes
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add downloads/
          # فقط در صورتی commit کن که تغییری وجود داشته باشد
          git commit -m "🧹 پاکسازی خودکار پوشه downloads [skip ci]" || echo "Nothing to commit"
          git push
